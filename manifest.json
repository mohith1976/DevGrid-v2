{
  "manifest_version": 3,
  "name": "DevGrid",
  "version": "1.0.0",
  "description": "Automatically synchronize accepted LeetCode submissions to GitHub",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
